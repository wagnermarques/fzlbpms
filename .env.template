# ============================================================================
# fzlbpms environment — SINGLE SOURCE OF TRUTH for host ports and credentials.
#
# Usage:  cp .env.template .env   (then adjust values; .env is gitignored)
#
# docker-compose.yml reads this file automatically and fails with a clear
# error if a variable is missing. Only HOST-side ports live here; ports
# internal to the fzl-network stay hard-coded in docker-compose.yml.
#
# The Maven parent POM (src-projects/mvn-artifacts/fzlparent) mirrors
# FZL_NEXUS_PORT_HTTP via its <fzl.nexus.port> property — keep them in sync
# or override at build time: mvn deploy -Dfzl.nexus.port=<port>
# ============================================================================

FZL_HOME=/path/to/fzlbpms


FZLBPMS_ADMIN_USERNAME=fzlbpmsadmin
FZLBPMS_ADMIN_PASSWORD=Admin@fzlbpms1


# --- nginx (web entrypoint: moodle, yii2 apps, sites) -----------------------
FZL_NGINX_PORT_HTTP=80
FZL_NGINX_PORT_FZLBPMS_APPS=8899
FZL_NGINX_PORT_SITES=8900

# --- MySQL (+ phpMyAdmin) ---------------------------------------------------
FZL_MYSQL_PORT=3316
FZL_MYSQL_ROOT_PASSWORD=changeme
FZL_MYSQL_DATABASE=fzl_db
FZL_MYSQL_USER=fzl_user
FZL_MYSQL_PASSWORD=changeme
FZL_PHPMYADMIN_PORT=8889

# --- PostgreSQL (main db: moodle, apps) -------------------------------------
FZL_POSTGRES_PORT=5432
FZL_POSTGRES_USER=postgres
FZL_POSTGRES_PASSWORD=changeme
FZL_POSTGRES_DB=fzldb

# --- Nexus 3 (maven artifact repository) ------------------------------------
# FZL_NEXUS_PORT_HTTP -> container 8081 (web UI + maven repos)
# FZL_NEXUS_PORT_DOCKER -> container 8082 (docker registry connector)
FZL_NEXUS_PORT_HTTP=8088
FZL_NEXUS_PORT_DOCKER=8082
# Admin credentials, consumed by containers/fzl-maven/settings.xml through the
# containerized `mvn` alias (ansible/commands-aliases.yml). On a fresh Nexus
# the password is generated — read it with:
#   docker exec fzl-nexus cat /nexus-data/admin.password
FZL_NEXUS_ADMIN_USER=admin
FZL_NEXUS_ADMIN_PASSWORD=change-me

# --- Keycloak (SSO) ---------------------------------------------------------
FZL_KEYCLOAK_PORT=8083
FZL_KEYCLOAK_ADMIN_USER=admin
FZL_KEYCLOAK_ADMIN_PASSWORD=changeme
FZL_KEYCLOAK_DB_NAME=keycloak
FZL_KEYCLOAK_DB_USER=keycloak
FZL_KEYCLOAK_DB_PASSWORD=changeme

# --- Flowable (BPM engine) --------------------------------------------------
FZL_FLOWABLE_UI_PORT=8080
FZL_FLOWABLE_DB_PORT=5435
FZL_FLOWABLE_DB_NAME=flowable
FZL_FLOWABLE_DB_USER=flowable
FZL_FLOWABLE_DB_PASSWORD=changeme

# --- BPMN drawer ------------------------------------------------------------
FZL_BPMN_DRAWER_PORT=8085

# --- GitLab CE --------------------------------------------------------------
FZL_GITLAB_PORT_HTTP=8086
FZL_GITLAB_PORT_SSH=2222
# GitLab validates password strength: use letters+digits+symbols, min 8 chars
FZL_GITLAB_ROOT_PASSWORD=changeme

# --- MongoDB (overleaf) -----------------------------------------------------
FZL_MONGO_USER=overleaf
FZL_MONGO_PASSWORD=changeme
FZL_MONGO_DATABASE=overleaf

# --- Elasticsearch / Kibana -------------------------------------------------
FZL_ELASTICSEARCH_PORT=9200
FZL_KIBANA_PORT=5601

# --- Dev / management UIs ---------------------------------------------------
FZL_ANGULAR_DEV_PORT=4200
FZL_PORTAINER_PORT_HTTP=9000
FZL_PORTAINER_PORT_TLS=9043

# --- Fakemail (host network, ports bind directly on host) -------------------
FZL_FAKEMAIL_WEB_PORT=5080
FZL_FAKEMAIL_MGMT_PORT=5081
FZL_FAKEMAIL_SMTP_PORT=8025
