<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>br.com.fzlbpms</groupId>
  <artifactId>fzlparent</artifactId>
  <version>1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>fzlparent</name>
  <url>http://maven.apache.org</url>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!--
        Nexus 3 (fzl-nexus service). These values mirror FZL_NEXUS_PORT_HTTP
        in the project root .env file (single source of truth) - keep in sync,
        or override at build time:  mvn deploy -Dfzl.nexus.port=NNNN

        fzl.nexus.host: use "localhost" when building on the host,
        "fzl-nexus" (port 8081) when building inside the fzl-network.
    -->
    <fzl.nexus.host>localhost</fzl.nexus.host>
    <fzl.nexus.port>8088</fzl.nexus.port>
    <fzl.nexus.url>http://${fzl.nexus.host}:${fzl.nexus.port}</fzl.nexus.url>
  </properties>

  <!--
      Nexus 3 repository layout (the old /nexus/content/repositories/... paths
      were for Nexus 2). Credentials go in ~/.m2/settings.xml under
      <server><id>nexus-releases</id> / <id>nexus-snapshots</id>.
  -->
  <distributionManagement>
    <repository>
      <id>nexus-releases</id>
      <url>${fzl.nexus.url}/repository/maven-releases/</url>
    </repository>
    <snapshotRepository>
      <id>nexus-snapshots</id>
      <url>${fzl.nexus.url}/repository/maven-snapshots/</url>
    </snapshotRepository>
  </distributionManagement>

</project>
